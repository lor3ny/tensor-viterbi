#!/bin/bash
#SBATCH --job-name=tensor-viterbi
#SBATCH --output=results/tensor_viterbi_%j.out
#SBATCH --error=results/tensor_viterbi_%j.err
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --time=00:30:00
#SBATCH --account=IscrC_FOCAL
#SBATCH --qos=boost_qos_dbg
#SBATCH --partition=boost_usr_prod
#SBATCH --gres=gpu:1


module load python
module load cuda

source /leonardo/home/userexternal/lpiarull/fast-viterbi/.venv/bin/activate

cd /leonardo/home/userexternal/lpiarull/fast-viterbi

python run_viterbi.py --system xeon8480/gnu --omp -m measure -dp data/50states_10000steps_1000dur.json
